FOOD_DIARY_USE_LOCAL_HASURA=true
FOOD_DIARY_USE_LOCAL_LABELLER=true
FOOD_DIARY_USE_LOCAL_LLM=true
HASURA_GRAPHQL_ADMIN_SECRET=
HASURA_GRAPHQL_JWT_SECRET=
# Path to the Gemma 4 E2B GGUF — shared by both llm-nutrition-api and nutrition-fact-labeller.
# Download: huggingface-cli download bartowski/google_gemma-4-E2B-it-GGUF google_gemma-4-E2B-it-Q5_K_M.gguf --local-dir /path/to/models --local-dir-use-symlinks False
GEMMA_MODEL_PATH=/path/to/models/google_gemma-4-E2B-it-Q5_K_M.gguf

# Optional: enable the VLM backend in the nutrition-fact-labeller service.
# Both must be set together; if either is absent the labeller falls back to PaddleOCR.
# VLM_MODEL_PATH can point at the same file as GEMMA_MODEL_PATH.
VLM_MODEL_PATH=/path/to/models/google_gemma-4-E2B-it-Q5_K_M.gguf
VLM_MMPROJ_PATH=/path/to/models/mmproj-google_gemma-4-E2B-it-f16.gguf
