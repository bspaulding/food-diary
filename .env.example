FOOD_DIARY_USE_LOCAL_HASURA=true
FOOD_DIARY_USE_LOCAL_LLM_NUTRITION_API=true
HASURA_GRAPHQL_ADMIN_SECRET=
HASURA_GRAPHQL_JWT_SECRET=

# llm-nutrition-api only ever proxies to a hosted LLM provider (no local
# inference) and serves both the image-labelling (/upload) and text-lookup
# (/lookup) endpoints. Both default to OpenRouter's free Gemma-4-31B model.
# LLM_API_KEY is tried first; OPENROUTER_API_KEY is accepted as a fallback.
LLM_API_KEY=sk-or-v1-...     # OpenRouter key (openrouter.ai/keys)
# LLM_MODEL=...              # optional; overrides BOTH endpoints' default model
# LLM_BASE_URL=...           # optional; overrides BOTH endpoints' default base URL

# Legacy fallback names, still accepted:
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
