FOOD_DIARY_USE_LOCAL_HASURA=true
FOOD_DIARY_USE_LOCAL_LABELLER=true
FOOD_DIARY_USE_LOCAL_LLM=true
HASURA_GRAPHQL_ADMIN_SECRET=
HASURA_GRAPHQL_JWT_SECRET=
GEMMA_MODEL_PATH=/path/to/gemma-4-E2B-it-Q5_K_M.gguf

# Optional: enable the VLM backend in the nutrition-fact-labeller service.
# Both must be set together; if either is absent the labeller falls back to PaddleOCR.
VLM_MODEL_PATH=nutrition-fact-labeller/vlm-models/gemma-4-e2b/gemma-4-E2B-it-Q4_K_M.gguf
VLM_MMPROJ_PATH=nutrition-fact-labeller/vlm-models/gemma-4-e2b/mmproj-F16.gguf
