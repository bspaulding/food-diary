# =========================
# 0. Builder stage
# =========================
FROM public.ecr.aws/docker/library/rust:1.91-bookworm AS builder

WORKDIR /app

# cmake is required by the llama-cpp-2 build script (compiles llama.cpp)
RUN apt-get update && apt-get install -y cmake && rm -rf /var/lib/apt/lists/*

# Cache dependency compilation separately from application source
COPY Cargo.toml Cargo.lock ./
RUN mkdir src && echo "fn main() {}" > src/main.rs
RUN cargo build --release && rm -rf src

COPY src ./src
RUN cargo install --path .

# =========================
# 1. Model download stage
# =========================
FROM public.ecr.aws/docker/library/debian:bookworm-slim AS downloader

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /models

# HF_TOKEN is optional — the bartowski repo is public, but a token avoids
# rate limiting on large downloads. Pass at build time:
#   docker build --build-arg HF_TOKEN=hf_... .
ARG HF_TOKEN=""
RUN curl -L --progress-bar \
    ${HF_TOKEN:+-H "Authorization: Bearer ${HF_TOKEN}"} \
    --output gemma-4-e2b-it-q5_k_m.gguf \
    "https://huggingface.co/bartowski/google_gemma-4-E2B-it-GGUF/resolve/main/google_gemma-4-E2B-it-Q5_K_M.gguf"

# =========================
# 2. Runtime stage
# =========================
FROM public.ecr.aws/docker/library/debian:bookworm-slim AS runtime

WORKDIR /app

# libstdc++6 and libgomp1 are required by the llama.cpp shared objects
# compiled into the binary (C++ runtime + OpenMP threading).
RUN apt-get update && apt-get install -y \
    ca-certificates \
    libstdc++6 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/cargo/bin/llm-nutrition-api /usr/local/bin/llm-nutrition-api
COPY --from=downloader /models/gemma-4-e2b-it-q5_k_m.gguf /models/gemma-4-e2b-it-q5_k_m.gguf

ENV GEMMA_MODEL_PATH=/models/gemma-4-e2b-it-q5_k_m.gguf
ENV PORT=3031

ENTRYPOINT ["llm-nutrition-api"]
