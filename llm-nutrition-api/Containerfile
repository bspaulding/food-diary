# =========================
# 0. Builder stage
# =========================
FROM public.ecr.aws/docker/library/debian:trixie-slim AS builder

RUN apt-get update && apt-get install -y \
    curl \
    xz-utils \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ARG ZIG_VERSION=0.16.0
ARG ZIG_SHA256=70e49664a74374b48b51e6f3fdfbf437f6395d42509050588bd49abe52ba3d00
RUN curl -fL -o /tmp/zig.tar.xz \
      "https://ziglang.org/download/${ZIG_VERSION}/zig-x86_64-linux-${ZIG_VERSION}.tar.xz" \
    && echo "${ZIG_SHA256}  /tmp/zig.tar.xz" | sha256sum -c - \
    && tar -xf /tmp/zig.tar.xz -C /usr/local \
    && mv "/usr/local/zig-x86_64-linux-${ZIG_VERSION}" /usr/local/zig \
    && rm /tmp/zig.tar.xz
ENV PATH="/usr/local/zig:${PATH}"

WORKDIR /app

# Copy build manifests first (for caching), then source.
COPY build.zig build.zig.zon ./
COPY src ./src

# -Dcpu=baseline is required: with no -Dtarget/-Dcpu given, Zig's default
# "native" resolution bakes in whatever CPU feature extensions (AVX-512,
# BMI2, etc.) the *build* machine happens to have, not just its arch/OS.
# That's fine when build and run machines match, but this image is built on
# GitHub Actions runners and run on DigitalOcean Kubernetes nodes with a
# different CPU -- the mismatch caused a SIGILL crash loop in production
# the first time a real request exercised a code path compiled to use an
# instruction the DOKS node's CPU doesn't support. baseline targets the
# generic x86_64 feature set, portable across any x86_64 Linux host.
RUN zig build exe -Doptimize=ReleaseFast -Dcpu=baseline

# =========================
# 1. Runtime stage
# =========================
# The binary built above is fully static (verified via `ldd`: "not a dynamic
# executable") -- no libc, no OpenSSL, nothing dynamic to link against at
# runtime. distroless/static ships exactly what a binary like that needs
# (CA certs, tzdata, a nonroot passwd entry) and nothing else: no shell, no
# package manager, no libc -- a meaningfully smaller image and attack
# surface than a full Debian userland, at the cost of no in-container shell
# for `kubectl exec`-style debugging.
#
# Pinned by digest (not :latest) so this build is reproducible the same way
# the builder stage's Zig download is (exact version + checksum) -- resolve
# a newer digest with:
#   docker buildx imagetools inspect gcr.io/distroless/static-debian13:latest
FROM gcr.io/distroless/static-debian13@sha256:9197324ba51d9cd071af8505989365c006adf9d6d2067eada25aef00abbb5278 AS runtime

WORKDIR /app

COPY --from=builder /app/zig-out/bin/llm-nutrition-api /usr/local/bin/llm-nutrition-api

ENTRYPOINT ["/usr/local/bin/llm-nutrition-api"]
